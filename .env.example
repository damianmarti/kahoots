# Example environment variables for Kahoot Results App
# Replace the values with your actual database credentials
DATABASE_URL=postgresql://username:password@localhost:5432/yourdbname
PASSWORD=

# Live quiz system
# Secret for signing admin session cookies (e.g. `openssl rand -hex 32`)
SESSION_SECRET=
# Vercel Blob token for question image uploads (Vercel project > Storage > Blob)
BLOB_READ_WRITE_TOKEN=
# URL pública del sitio, sin barra final (para los meta Open Graph / imagen de share)
# Por defecto usa https://kahoots.vercel.app; setear solo si cambia el dominio
NEXT_PUBLIC_SITE_URL=